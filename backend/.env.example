PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/placementhub
JWT_SECRET=placementhub_secret_key
JWT_EXPIRE=30d
CLIENT_URL=http://localhost:5173

# Nodemailer SMTP settings (If left empty, system automatically falls back to Ethereal mock account)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL="PlacementHub Support" <support@placementhub.com>
